# Normalize all text files to LF in the repo
* text=auto eol=lf

# Explicitly declare text files
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files — never convert
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff binary
*.woff2 binary
